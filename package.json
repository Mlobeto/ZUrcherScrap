{
  "name": "scrapzurcher",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "dev:api": "npm run dev -w @scrapzurcher/api",
    "dev:web": "npm run dev -w @scrapzurcher/web",
    "dev:worker": "npm run dev -w @scrapzurcher/worker",
    "scrape": "npm run scrape -w @scrapzurcher/worker",
    "build": "npm run build -w @scrapzurcher/api && npm run build -w @scrapzurcher/web && npm run build -w @scrapzurcher/worker"
  },
  "devDependencies": {
    "prisma": "^6.9.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  }
}
